{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"apps/web/src/**/*",
			"apps/web/vite.config.ts",
			"apps/api/src/**/*",
			"apps/api/scripts/**/*",
			"packages/subframe/**/*",
			"packages/schemas/**/*",
			"!**/routeTree.gen.ts",
			"!**/styles.css",
			"!**/node_modules/**"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	}
}
