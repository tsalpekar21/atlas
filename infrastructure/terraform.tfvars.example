# Copy to terraform.tfvars and fill in. Do not commit terraform.tfvars if it contains secrets.

project_id              = "your-gcp-project-id"
region                  = "us-central1"
github_owner            = "your-github-org-or-username"
github_repo             = "atlas"
github_connection_name  = "github-atlas"   # Name from Cloud Build Console after connecting the repo
github_branch           = "main"

# Optional overrides
# cloud_run_service_name   = "atlas-bot"
# artifact_registry_repo   = "atlas"

# Set to true on first apply (deploys a public hello-world image so Cloud Run succeeds).
# After the first Cloud Build trigger runs, set to false to use the real image from Artifact Registry.
use_placeholder_image      = true

# Sensitive values — keep out of version control
openai_api_key             = "sk-..."
google_generative_ai_api_key = "your-google-ai-key"

# API service (Hono + Mastra)
database_url               = "postgres://user:pass@host/mastra?sslmode=require"
api_cloud_run_service_name = "atlas-api"
api_token                  = "your-secure-api-token"
