# Copy to terraform.tfvars and fill in. Do not commit terraform.tfvars if it contains secrets.

project_id              = "your-gcp-project-id"
region                  = "us-central1"
github_owner            = "your-github-org-or-username"
github_repo             = "atlas"
github_connection_name  = "github-atlas"   # Name from Cloud Build Console after connecting the repo
github_branch           = "main"

# Optional overrides
# cloud_run_service_name   = "atlas-web"
# artifact_registry_repo   = "atlas"

# Set to true on first apply (deploys a public hello-world image so Cloud Run succeeds).
# After the first Cloud Build trigger runs, set to false to use the real image from Artifact Registry.
use_placeholder_image      = true

# Sensitive values — keep out of version control
openai_api_key             = "sk-..."
google_generative_ai_api_key = "your-google-ai-key"

# API service (Hono + Mastra)
database_url               = "postgres://user:pass@host/mastra?sslmode=require"
api_cloud_run_service_name = "atlas-api"

# Better Auth (API). Secret must be >= 32 random characters.
better_auth_secret = "replace-with-at-least-32-random-characters"

# Browser origins allowed for CORS + Better Auth (comma-separated).
# Use your custom domain (e.g. https://atlashealth.dev) or the Cloud Run URL from `terraform output bot_cloud_run_url`.
trusted_origins = "https://your-domain.example.com"

# Optional: public web URL for absolute client links (VITE_FRONTEND_URL).
# vite_frontend_url = "https://your-domain.example.com"

# Public URL of the API service (custom domain or Cloud Run URL).
# api_url = "https://api.your-domain.example.com"

firecrawl_signing_secret = "test"

firecrawl_api_key = "test"