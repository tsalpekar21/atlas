# PostgreSQL (run via Docker Compose from repo root: docker compose up -d)
# App database (default postgres DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# OpenAI
OPENAI_API_KEY=sk-...

# Mastra AI server (apps/ai)
MASTRA_SERVER_URL=http://localhost:4111
MASTRA_API_TOKEN=

# Copy to .env or .env.local and set real values. Do not commit .env.
