{
  "name": "@atlas/api",
  "private": true,
  "type": "module",
  "exports": {
    "./app": "./src/app.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "studio": "pnpm mastra studio --port 3001",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "scrape:rupa": "tsx src/scripts/scrape-rupa.ts",
    "diagnose:rag": "tsx src/scripts/diagnose-rag.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm test:integration",
    "eval:seed": "tsx src/eval/seed/run.ts",
    "eval:ab": "tsx src/eval/experiment/run.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@atlas/logger": "workspace:*",
    "@atlas/schemas": "workspace:*",
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@google-cloud/tasks": "^6.2.1",
    "@grpc/grpc-js": "^1.14.3",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@mastra/ai-sdk": "^1.3.3",
    "@mastra/auth-better-auth": "^1.0.2",
    "@mastra/core": "^1.24.1",
    "@mastra/hono": "^1.4.3",
    "@mastra/loggers": "^1.1.1",
    "@mastra/memory": "^1.15.0",
    "@mastra/observability": "^1.9.0",
    "@mastra/pg": "^1.9.0",
    "@mastra/rag": "^2.2.0",
    "@mendable/firecrawl-js": "^4.18.1",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "^6.0.116",
    "better-auth": "^1.5.6",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "fast-xml-parser": "^5.5.11",
    "hono": "^4.12.12",
    "mastra": "^1.5.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mastra/deployer-vercel": "^1.1.4",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.5.2",
    "testcontainers": "^11.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
