# API storage database (run via Docker Compose from repo root: docker compose up -d)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mastra

# After clone or schema changes: pnpm --filter @atlas/api db:migrate

# Google AI (used by triage agent)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# NCBI E-utilities (used by the PubMed search tool inside background research
# workers). Optional; without a key the tool still works but is rate-limited
# to 3 req/s instead of 10 req/s. Register at https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# Better Auth (required for auth; secret must be >= 32 random chars)
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
# Public URL of this API (used by Better Auth and cookies)
BETTER_AUTH_URL=http://localhost:4111
# Comma-separated browser origins (web app) for CORS + Better Auth trustedOrigins
TRUSTED_ORIGINS=http://localhost:3000

# Bearer token Mastra Studio (and any direct Mastra API consumers) must send
# as `Authorization: Bearer <key>` to hit `/api/*` Mastra routes. Generate
# locally with: `openssl rand -hex 48`. Production value lives in Google
# Cloud Secret Manager (atlas-api-mastra-api-key) and is wired in via Terraform.
MASTRA_API_KEY=a37be8bae865ae29ce83316dd6f74bad3bd5063f570e685077effaa5096f398afa62146d5de5930df98c0140b039c432
