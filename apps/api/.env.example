# API storage database (run via Docker Compose from repo root: docker compose up -d)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mastra

# After clone or schema changes: pnpm --filter @atlas/api db:migrate

# Google AI (used by triage agent)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# Better Auth (required for auth; secret must be >= 32 random chars)
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
# Public URL of this API (used by Better Auth and cookies)
BETTER_AUTH_URL=http://localhost:4111
# Comma-separated browser origins (web app) for CORS + Better Auth trustedOrigins
TRUSTED_ORIGINS=http://localhost:3000
