# Mastra storage database (run via Docker Compose from repo root: docker compose up -d)
MASTRA_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mastra

# Google AI (used by triage agent)
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key

# API token for authenticating requests from the bot app (leave empty to disable auth in dev)
MASTRA_API_TOKEN=dev-token-change-in-production
