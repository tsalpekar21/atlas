# Public base URL of the API (Better Auth client + fetch). No trailing slash.
VITE_API_URL=http://localhost:4111

# Optional. Public web origin for absolute links (e.g. triage). Leave unset for same-origin relative URLs.
VITE_FRONTEND_URL=http://localhost:3000

# Optional. Set to "true" to enable the dev-only debug snapshot panels in the chat UI.
# Baked into the client bundle at Vite build time — must be present during `pnpm build`.
VITE_SHOW_DEBUG_SNAPSHOTS=true
